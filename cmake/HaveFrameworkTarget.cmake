macro(have_modules_contrib_target project_root_path)
  if(TARGET vstream_contrib)
    set(HAVE_MODULES_CONTRIB_TARGET TRUE)
    set(HAVE_MODULES_CONTRIB TRUE)
  else()
    if(EXISTS ${project_root_path}/lib/libvstream_contrib.so)
      set(HAVE_MODULES_CONTRIB TRUE)
      link_directories(${project_root_path}/lib)
    endif()
  endif()
  if (NOT DEFINED VSTREAM_LIB_PATH)
    set(VSTREAM_LIB_PATH ${project_root_path}/lib PARENT_SCOPE)
  endif()
endmacro()
